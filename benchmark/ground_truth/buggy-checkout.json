      "selector": null,
      "keywords": ["support", "dead end", "unavailable", "no options"]
    },
    {
      "id": "bc-004",
      "type": "mobile_tap_target",
      "severity": "medium",
      "url_pattern": "/cart",
      "description": "Remove item button is too small for mobile tap (4px padding)",
      "selector": ".btn-tiny",
      "keywords": ["tiny", "small", "tap", "mobile", "remove", "button"]
    },
    {
