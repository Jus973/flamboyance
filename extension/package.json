{
  "name": "flamboyance",
  "displayName": "Flamboyance – UX Friction Agent",
  "description": "Spawn synthetic browser agents to detect UX friction in web apps via Playwright.",
  "version": "0.1.0",
  "publisher": "flamboyance",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onView:flamboyance.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flamboyance",
          "title": "Flamboyance",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "flamboyance": [
        {
          "type": "webview",
          "id": "flamboyance.sidebar",
          "name": "UX Friction Monitor"
        }
      ]
    },
    "commands": [
      {
        "command": "flamboyance.runSimulation",
        "title": "Flamboyance: Run Simulation"
      },
      {
        "command": "flamboyance.stopSimulation",
        "title": "Flamboyance: Stop Simulation"
      },
      {
        "command": "flamboyance.showReport",
        "title": "Flamboyance: Show Report"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
